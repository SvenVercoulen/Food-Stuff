<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/stats_card"
    android:padding="16dp"
    android:layout_marginBottom="14dp"
    android:elevation="2dp">

    <TextView
        android:id="@+id/tvCardName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Name"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#0D47A1"
        android:layout_marginBottom="12dp"/>

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:alignmentMode="alignMargins">

        <TextView
            android:id="@+id/tvCardEat"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:text="Meals today: 0"
            android:textSize="15sp"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvCardDrink"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:text="Drinks today: 0"
            android:textSize="15sp"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvCardOutsideMins"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:text="Outside today: 0m"
            android:textSize="15sp"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvCardOutsideWeek"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:text="Outside week: 0x"
            android:textSize="15sp"
            android:layout_marginBottom="6dp"/>
    </GridLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#D0D0D0"
        android:layout_marginVertical="8dp"/>

    <TextView
        android:id="@+id/tvCardLastEat"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Last meal: Never"
        android:textSize="13sp"
        android:textColor="#555555"
        android:layout_marginBottom="2dp"/>

    <TextView
        android:id="@+id/tvCardLastDrink"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Last drink: Never"
        android:textSize="13sp"
        android:textColor="#555555"/>
</LinearLayout>