<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/main_background"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Resident List"
        android:textSize="28sp"
        android:textColor="#0D47A1"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"/>

    <!-- The Dark Blue Container for the List -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:background="@drawable/list_container"
        android:layout_marginBottom="24dp">

        <ListView
            android:id="@+id/userListView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:divider="#BBDEFB"
            android:dividerHeight="1dp" />
    </LinearLayout>

    <!-- Bottom Buttons -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:alignmentMode="alignMargins">

        <Button
            android:id="@+id/btnStats"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            android:background="@drawable/btn_dark_blue"
            android:textColor="#FFFFFF"
            android:text="STATISTICS" />

        <Button
            android:id="@+id/btnPredict"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            android:background="@drawable/btn_dark_blue"
            android:textColor="#FFFFFF"
            android:text="PREDICTION" />

        <Button
            android:id="@+id/btnEditData"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            android:background="@drawable/btn_dark_blue"
            android:textColor="#FFFFFF"
            android:text="EDIT DATA" />

        <Button
            android:id="@+id/btnAddUser"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            android:background="@drawable/btn_dark_blue"
            android:textColor="#FFFFFF"
            android:text="ADD RESIDENT" />
    </GridLayout>

</LinearLayout>